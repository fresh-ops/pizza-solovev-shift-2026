    {
      "url": ""
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "89990009999"
          }
        },
        "required": ["phone"]
      },
      "OtpResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Статус запроса"
          },
          "reason": {
            "type": "string",
            "description": "Причина ошибки"
          },
          "retryDelay": {
            "type": "number",
            "example": 120000,
            "description": "Время запроса повторного отп кода в мс"
          }
        },
        "required": ["success", "retryDelay"]
      },
      "SignInDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "89990009999",
            "description": "Номер телефона"
          },
          "code": {
            "type": "number",
            "example": 345231,
            "description": "Отп код"
          }
        },
        "required": ["phone", "code"]
      },
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "ID пользователя"
          },
          "phone": {
            "type": "string",
            "example": "89990009999",
            "description": "Номер телефона"
          },
          "firstname": {
            "type": "string",
            "example": "firstname",
            "description": "Имя"
          },
          "middlename": {
            "type": "string",
            "example": "middlename",
            "description": "Отчество"
          },
          "lastname": {
            "type": "string",
            "example": "lastname",
            "description": "Фамилия"
          },
          "email": {
            "type": "string",
            "example": "email@gmail.com",
            "description": "Почта"
          },
          "city": {
            "type": "string",
            "example": "city",
            "description": "Город"
          }
        },
        "required": ["_id", "phone"]
      },
      "SignInResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Статус запроса"
          },
          "reason": {
            "type": "string",
            "description": "Причина ошибки"
          },
          "user": {
            "description": "Пользователь",
            "allOf": [
              {
                "$ref": "#/components/schemas/User"
              }
            ]
          },
          "token": {
            "type": "string",
            "description": "Пользовательский токен"
          }
        },
        "required": ["success", "user", "token"]
      },
      "UpdateProfileProfileDto": {
        "type": "object",
        "properties": {
          "firstname": {
            "type": "string",
            "example": "firstname",
            "description": "Имя"
          },
          "middlename": {
            "type": "string",
            "example": "middlename",
            "description": "Отчество"
          },
          "lastname": {
            "type": "string",
            "example": "lastname",
            "description": "Фамилия"
          },
          "email": {
            "type": "string",
            "example": "email@gmail.com",
            "description": "Почта"
          },
          "city": {
            "type": "string",
            "example": "city",
            "description": "Город"
          }
        }
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "profile": {
            "description": "Данные пользователя",
            "allOf": [
              {
                "$ref": "#/components/schemas/UpdateProfileProfileDto"
              }
            ]
          },
          "phone": {
            "type": "string",
            "example": "89990009999",
            "description": "Номер телефона"
          }
        },
        "required": ["profile", "phone"]
      },
      "UpdateProfileResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Статус запроса"
          },
          "reason": {
            "type": "string",
            "description": "Причина ошибки"
          },
          "user": {
            "description": "Пользователь",
            "allOf": [
              {
                "$ref": "#/components/schemas/User"
              }
            ]
          }
        },
        "required": ["success", "user"]
      },
      "SessionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Статус запроса"
          },
          "reason": {
            "type": "string",
            "description": "Причина ошибки"
          },
          "user": {
            "description": "Пользователь",
            "allOf": [
              {
                "$ref": "#/components/schemas/User"
              }
            ]
          }
        },
        "required": ["success", "user"]
      },
      "Ingredient": {
        "type": "string",
        "enum": [
          "pineapple",
          "mozzarella",
          "pepperoni",
          "green_pepper",
          "mushrooms",
          "basil",
          "cheddar",
          "parmesan",
          "feta",
          "ham",
          "pickle",
          "tomato",
          "bacon",
          "onion",
          "chile",
          "shrimp",
          "chicken_fillet",
          "meatballs"
        ],
        "description": "Идентификатор ингредиента"
      },
      "PizzaIngredient": {
        "type": "object",
        "properties": {
          "type": {
            "example": "pineapple",
            "description": "Идентификатор ингредиента",
            "allOf": [
              {
                "$ref": "#/components/schemas/Ingredient"
              }
            ]
          },
          "price": {
            "type": "number",
            "description": "Цена ингредиента"
          },
          "img": {
            "type": "string",
            "description": "Изображение ингредиента"
          }
        },
        "required": ["type", "price", "img"]
      },
      "Size": {
        "type": "string",
        "enum": ["small", "medium", "large"],
        "description": "Идентификатор размера пиццы"
      },
      "PizzaSize": {
        "type": "object",
        "properties": {
          "type": {
            "example": "small",
            "description": "Идентификатор размера пиццы",
            "allOf": [
              {
                "$ref": "#/components/schemas/Size"
              }
            ]
          },
          "price": {
            "type": "number",
            "description": "Цена пиццы"
          }
        },
        "required": ["type", "price"]
      },
      "Dough": {
        "type": "string",
        "enum": ["thin", "thick"],
        "description": "Идентификатор типа теста"
      },
      "PizzaDough": {
        "type": "object",
        "properties": {
          "type": {
            "example": "thin",
            "description": "Идентификатор типа теста",
            "allOf": [
              {
                "$ref": "#/components/schemas/Dough"
              }
            ]
          },
          "price": {
            "type": "number",
            "description": "Цена теста"
          }
        },
        "required": ["type", "price"]
      },
      "Pizza": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1",
            "description": "Идентификатор пиццы"
          },
          "name": {
            "type": "string",
            "description": "Название пиццы"
          },
          "ingredients": {
            "description": "Ингредиенты",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PizzaIngredient"
            }
          },
          "toppings": {
            "description": "Топпинги",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PizzaIngredient"
            }
          },
          "description": {
            "type": "string",
            "description": "Описание пиццы"
          },
          "sizes": {
            "description": "Размеры пиццы",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PizzaSize"
            }
          },
          "doughs": {
            "description": "Тип теста",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PizzaDough"
            }
          },
          "calories": {
            "type": "number",
            "description": "Количество калорий"
          },
          "protein": {
            "type": "string",
            "description": "Количество белков"
          },
          "totalFat": {
            "type": "string",
            "description": "Количество жиров"
          },
          "carbohydrates": {
            "type": "string",
            "description": "Количество углеводов"
          },
          "sodium": {
            "type": "string",
            "description": "Количество натрия"
          },
          "allergens": {
            "description": "Список аллергенов",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isVegetarian": {
            "type": "boolean",
            "description": "Для вегетарианцев"
          },
          "isGlutenFree": {
            "type": "boolean",
            "description": "Наличие глютена"
          },
          "isNew": {
            "type": "boolean",
            "description": "Новинка"
          },
          "isHit": {
            "type": "boolean",
            "description": "Хит"
          },
          "img": {
            "type": "string",
            "description": "Изображение пиццы"
          }
        },
        "required": [
          "id",
          "name",
          "ingredients",
          "toppings",
          "description",
          "sizes",
          "doughs",
          "calories",
          "protein",
          "totalFat",
          "carbohydrates",
          "sodium",
          "allergens",
          "isVegetarian",
          "isGlutenFree",
          "isNew",
          "isHit",
          "img"
        ]
      },
      "PizzasResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Статус запроса"
          },
          "reason": {
            "type": "string",
            "description": "Причина ошибки"
          },
          "catalog": {
            "description": "Пиццы",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Pizza"
            }
          }
        },
        "required": ["success", "catalog"]
      },
      "CreatePizzaPaymentAddressDto": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string",
            "example": "street",
            "description": "Улица"
          },
          "house": {
            "type": "string",
            "example": "house",
            "description": "Номер дома"
          },
          "apartment": {
            "type": "string",
            "example": "apartment",
            "description": "Номер квартиры"
          },
          "comment": {
            "type": "string",
            "example": "comment",
            "description": "Комментарий"
          }
        },
        "required": ["street", "house", "apartment"]
      },
      "CreatePizzaPaymentPersonDto": {
        "type": "object",
        "properties": {
          "firstname": {
            "type": "string",
            "example": "firstname",
            "description": "Имя"
          },
          "lastname": {
            "type": "string",
            "example": "lastname",
            "description": "Фамилия"
          },
          "middlename": {
            "type": "string",
            "example": "middlename",
            "description": "Отчество"
          },
          "phone": {
            "type": "string",
            "example": "89990009999",
            "description": "Телефон"
          }
        },
        "required": ["firstname", "lastname", "phone"]
      },
      "CreatePizzaPaymentDebitCardDto": {
