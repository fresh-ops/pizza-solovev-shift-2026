          },
          "expireDate": {
            "type": "string",
            "example": "11/11",
            "description": "Срок действие карты"
          },
          "cvv": {
            "type": "string",
            "example": "111",
            "description": "Код карты"
          }
        },
        "required": ["pan", "expireDate", "cvv"]
      },
      "OrderedPizza": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1",
            "description": "Идентификатор пиццы"
          },
          "toppings": {
            "type": "array",
            "example": ["pineapple", "chile"],
            "description": "Топпинги",
            "items": {
              "$ref": "#/components/schemas/Ingredient"
